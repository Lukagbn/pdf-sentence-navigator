{
  "manifest_version": 3,
  "name": "PDF Sentence Navigator",
  "version": "1.0",
  "description": "Keyboard navigation between sentences in a PDF document.",

  "permissions": ["webNavigation", "tabs"],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "Open in PDF Sentence Navigator"
  }
}
